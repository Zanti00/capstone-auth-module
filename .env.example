# =============================================================
#  Docker Compose — Environment Variables Template
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# =============================================================

# --- Application ---
APP_ENV=local
APP_DEBUG=true

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# MySQL container (must match DB_ values above)
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=

# --- Redis ---
REDIS_HOST=redis

# --- Mail (e.g. Mailtrap sandbox credentials) ---
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
